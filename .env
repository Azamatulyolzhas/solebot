# ─── SoleBot — переменные окружения ───────────────────────────────────

# ── Groq AI (обязательно) ────────────────────────────────────────────
# Получить бесплатно: https://console.groq.com → API Keys
GROQ_API_KEY=

# ── Telegram ─────────────────────────────────────────────────────────
# 1. Напишите @BotFather в Telegram → /newbot → получите токен
TELEGRAM_BOT_TOKEN=
# 2. URL вашего сервера (нужен HTTPS!)
TELEGRAM_WEBHOOK_URL=

# ── WhatsApp Business API ─────────────────────────────────────────────
# Получить на: https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Придумайте любое слово для верификации webhook
WHATSAPP_VERIFY_TOKEN=

# ── Instagram Messenger API ───────────────────────────────────────────
# Получить на: https://developers.facebook.com → Instagram → Webhooks
INSTAGRAM_TOKEN=
INSTAGRAM_VERIFY_TOKEN=

# ── База данных ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.kuwcuiijmfvxweiiszqc:Aolzhas2006%24@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET=8f6b2e5a5d6731f56e764a4d4c99d6df927563158081c017bd6cf5e153e6038c

# ── Оплата подписки (ручная) ──────────────────────────────────────────
# Номер Kaspi Gold для перевода
PAYMENT_KASPI=                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
