# ── Email-уведомления (Resend) ────────────────────────────────────────
# Получить API-ключ: https://resend.com → API Keys (бесплатно 3000 писем/мес)
RESEND_API_KEY=
# От какого адреса отправлять письма (нужен верифицированный домен в Resend)
# Для тестов можно использовать onboarding@resend.dev (только на ваш собственный email)
EMAIL_FROM=onboarding@resend.dev
# Публичный URL вашего приложения (для кнопки "Открыть кабинет" в письме)
