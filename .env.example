GROQ_API_KEY=
USE_CREWAI=false
CREWAI_MODEL=llama-3.3-70b-versatile
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

DATABASE_URL=
REDIS_URL=

# Platform admin: same email as your shop account, or a separate password below
ADMIN_EMAIL=
# Optional — only if admin password differs from shop login
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
JWT_SECRET=
# Email (Resend) — заказы и подписка на owner_email регистрации
# 1) RESEND_API_KEY с resend.com
# 2) Добавьте домен в /admin → Email, пропишите DNS у регистратора
# 3) После verify домена письма уйдут на ЛЮБОЙ email клиента (авто noreply@ваш-домен)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=SaleBot
SHOP_DASHBOARD_URL=https://your-app.up.railway.app

RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW_SECONDS=60
SESSION_TTL_SECONDS=86400

WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=mysecret

INSTAGRAM_TOKEN=
INSTAGRAM_VERIFY_TOKEN=mysecret

DB_PATH=sneakers.db
SHOP_SLUG=default
SHOP_NAME=Default shop
